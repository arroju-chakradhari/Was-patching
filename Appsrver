---
- name: Patch App Server
  hosts: app
  become: yes
  remote_user: rlms
  gather_facts: no

  vars:
    was_home: /rlms/IBM/WebSphere/AppServer

    imcl: /rlms/IBM/InstallationManager/eclipse/tools/imcl

    repo_was: /rlms/soft/Fix5.26/repository.config
    repo_java: /rlms/soft/JAVA_8.0.8.55/repository.config

    shared_dir: /rlms/IBM/InstallationManager/IMShared

    node_profile: D2R1MSGAPP1

    dmgr_host: 10.191.154.127

    was_fixpack: com.ibm.websphere.ND.v90_9.0.5026.20251114_1520
    java_fixpack: com.ibm.java.jdk.v8_8.0.8055.20251007_2253

  tasks:

  - name: Backup cacerts
    copy:
      src: "{{ was_home }}/java/8.0/jre/lib/security/cacerts"
      dest: "/rlms/soft/cacerts_app"
      remote_src: yes

  - name: Stop Application Servers
    shell: |
      for s in $(ls {{ was_home }}/profiles/{{ node_profile }}/servers); do
        if [ "$s" != "nodeagent" ]; then
          echo "Stopping $s"
          {{ was_home }}/bin/stopServer.sh $s -profileName {{ node_profile }}
        fi
      done

  - name: Stop NodeAgent
    shell: "{{ was_home }}/bin/stopNode.sh -profileName {{ node_profile }}"
    ignore_errors: yes

  - name: Apply Fixpack
    shell: >
      {{ imcl }} install
      {{ was_fixpack }}
      {{ java_fixpack }}
      -repositories {{ repo_was }},{{ repo_java }}
      -installationDirectory {{ was_home }}
      -sharedResourcesDirectory {{ shared_dir }}
      -acceptLicense -sVP -silent

  - name: Validate Version
    shell: "{{ was_home }}/bin/versionInfo.sh"
    register: version_output

  - name: Check Version
    fail:
      msg: "Patch verification failed"
    when: "'9.0.5.26' not in version_output.stdout"

  - name: Restore cacerts
    copy:
      src: "/rlms/soft/cacerts_app"
      dest: "{{ was_home }}/java/8.0/jre/lib/security/cacerts"
      remote_src: yes

  - name: Start NodeAgent
    shell: "{{ was_home }}/bin/startNode.sh -profileName {{ node_profile }}"

  - name: Sync Node
    shell: >
      {{ was_home }}/bin/syncNode.sh
      {{ dmgr_host }}
      8879
      -username wasadmin
      -password wasadmin

  - name: Start Application Servers
    shell: |
      for s in $(ls {{ was_home }}/profiles/{{ node_profile }}/servers); do
        if [ "$s" != "nodeagent" ]; then
          echo "Starting $s"
          {{ was_home }}/bin/startServer.sh $s -profileName {{ node_profile }}
        fi
      done
